rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow any authenticated user (including Anonymous) to save a score
    match /leaderboard/{scoreId} {
      allow read: if true; // Everyone can see the leaderboard
      allow write: if request.auth != null; // Only logged-in students can save
    }
    
    // Allow users to manage their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
