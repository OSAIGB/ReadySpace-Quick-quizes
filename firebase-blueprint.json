{
  "entities": {
    "User": {
      "title": "User",
      "description": "Student profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email"]
    },
    "QuizResult": {
      "title": "Quiz Result",
      "description": "Result of a completed quiz session",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "subject": { "type": "string" },
        "topic": { "type": "string" },
        "score": { "type": "number" },
        "totalQuestions": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" },
        "cheated": { "type": "boolean" }
      },
      "required": ["userId", "userName", "subject", "score", "totalQuestions", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Individual student records"
    },
    "/results/{resultId}": {
      "schema": "QuizResult",
      "description": "Historical quiz performance and leaderboard data"
    }
  }
}
